* text=auto

# Source and docs as LF for consistent diffs
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# PowerShell scripts keep Windows-native endings
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.zip binary
