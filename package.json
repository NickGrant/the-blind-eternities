{
  "name": "blind-eternities",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "package": "git archive -o source.zip HEAD",
    "art:cache": "node scripts/cache-plane-art.mjs",
    "art:cache:dry": "node scripts/cache-plane-art.mjs --dry-run",
    "art:cache:fetch": "node scripts/cache-plane-art.mjs --fetch --max=2 --delay-ms=1500",
    "cards:sync:mtgjson": "node scripts/sync-cards-from-mtgjson.mjs",
    "docs:normalize:issues": "node scripts/normalize-issues.mjs",
    "build:pages": "ng build --base-href=/the-blind-eternities/",
    "deploy:pages": "angular-cli-ghpages --dir=dist/blind-eternities/browser"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "phaser": "^3.90.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "angular-cli-ghpages": "^3.0.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
